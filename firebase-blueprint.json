{
  "entities": {
    "Medication": {
      "title": "Medication",
      "description": "Available medicine or health product in the pharmacy",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "stock": { "type": "integer" },
        "imageUrl": { "type": "string" },
        "requiresPrescription": { "type": "boolean" }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Online prescription or medication order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "medicationId": { "type": "string" },
              "quantity": { "type": "integer" },
              "price": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "shippingAddress": { "type": "string" }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Pharmacist consultation appointment",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] },
        "pharmacistName": { "type": "string" }
      },
      "required": ["userId", "dateTime", "status"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Extended user information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["userId", "email"]
    }
  },
  "firestore": {
    "/medications/{medicationId}": {
      "schema": "Medication",
      "description": "Medications inventory"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Pharmacist appointments"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    }
  }
}
