rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "manavgujaran@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins
    match /admins/{userId} {
      allow read: if isSignedIn(); // Let people check if they are admin
    }

    // Medications: Public read, Admin write
    match /medications/{medicationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: User can read/create their own orders. Admin can read/update all.
    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && (isOwner(existing().userId) || isOwner(incoming().userId)));
      allow create: if isSignedIn() && isOwner(incoming().userId) 
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
      allow update: if isAdmin() || (isSignedIn() && isOwner(existing().userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'shippingAddress'])
        && (existing().status == 'pending'));
    }

    // Appointments: User can manage their own appointments. Admin can manage all.
    match /appointments/{appointmentId} {
      allow read: if isAdmin() || (isSignedIn() && (isOwner(existing().userId) || isOwner(incoming().userId)));
      allow create: if isSignedIn() && isOwner(incoming().userId)
        && incoming().status == 'scheduled';
      allow update: if isAdmin() || (isSignedIn() && isOwner(existing().userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'dateTime', 'reason']));
      allow delete: if isAdmin() || (isSignedIn() && isOwner(existing().userId) && existing().status == 'scheduled');
    }

    // Users: User can read/write their own profile. Admin can read all.
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && isOwner(userId));
      allow create, update: if isAdmin() || (isSignedIn() && isOwner(userId)
        && (incoming().userId == userId));
    }
  }
}
